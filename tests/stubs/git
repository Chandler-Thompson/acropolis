#!/bin/bash
# git stub: handles `git clone` and `git -C <dir> pull --ff-only`
# Captures the -C <dir> directory so `pull` can mimic real git, which fails
# when run against a path that is not a git repository.
args=()
cdir=""
skip_next=false
for arg in "$@"; do
    if $skip_next; then
        cdir="$arg"
        skip_next=false
        continue
    fi
    if [ "$arg" = "-C" ]; then
        skip_next=true
        continue
    fi
    args+=("$arg")
done

cmd="${args[0]:-}"
case "$cmd" in
    clone)
        dest="${args[-1]}"
        mkdir -p "$dest/.git"
        # Fabricate a minimal but realistic Workshop: install creates the runtime
        # tree (outside the acropolis tree), and cleanup removes it but ONLY when
        # driven non-interactively with --yes — mirroring the contract that
        # `acropolis teardown` depends on. If teardown forgets the flag, the tree
        # is left behind and the leave-no-trace assertions fail.
        printf '#!/bin/bash\nmkdir -p "$HOME/.local/share/workshop"\n' > "$dest/install.sh"
        printf '#!/bin/bash\necho "workshop session launched"\n' > "$dest/setup_workshop.sh"
        printf '#!/bin/bash\n[ "${1:-}" = "--yes" ] || exit 1\nrm -rf "$HOME/.local/share/workshop"\n' > "$dest/cleanup.sh"
        chmod +x "$dest/install.sh" "$dest/setup_workshop.sh" "$dest/cleanup.sh"
        ;;
    pull)
        # Record the full pull invocation so tests can assert how update pulls.
        [ -n "${ACROPOLIS_TEST_PULLLOG:-}" ] && printf '%s\n' "$*" >> "$ACROPOLIS_TEST_PULLLOG"
        target="${cdir:-.}"
        if [ ! -d "$target/.git" ]; then
            echo "fatal: not a git repository: $target" >&2
            exit 128
        fi
        exit 0
        ;;
esac
exit 0
